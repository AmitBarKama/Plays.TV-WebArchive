# memoryTV backend — environment variables (all optional; sensible defaults).

# Persistent state dir. In production point this at a mounted volume so the
# SQLite cache + downloaded clips survive restarts/redeploys.
MEMORYTV_DATA_DIR=/data

# CORS allow-list for a separately-hosted frontend (e.g. Vercel). Comma-separated.
# Default "*" is fine (public data, no cookies). Tighten to your domain if you like:
# MEMORYTV_ALLOWED_ORIGINS=https://your-frontend.vercel.app
MEMORYTV_ALLOWED_ORIGINS=*

# PORT is injected by the host (Railway/Fly/Render). Local default is 8000.
# PORT=8000
